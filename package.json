{
  "name": "payjoin",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "",
  "main": "index.js",
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "scripts": {
    "build": "rimraf ./build && tsc",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma generate && npx prisma migrate deploy",
    "start": "npm run db:deploy && node -r dotenv/config -r tsconfig-paths/register --enable-source-maps build/index.js",
    "start:dev": "npx prisma migrate dev && ts-node-dev --respawn --transpile-only --ignore-watch node_modules --no-notify -r tsconfig-paths/register -r dotenv/config src/index.ts",
    "test": "jest --config jest.config.js --forceExit --runInBand",
    "lint": "eslint . --ext .ts",
    "lintfix": "eslint . --ext .ts --fix"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/axios": "0.14.4",
    "@types/dinero.js": "1.9.4",
    "@types/express": "5.0.1",
    "@types/jest": "29.5.14",
    "@types/node": "22.13.13",
    "@typescript-eslint/eslint-plugin": "8.28.0",
    "@typescript-eslint/parser": "8.28.0",
    "eslint": "9.39.4",
    "eslint-plugin-prettier": "5.2.4",
    "globals": "15.15.0",
    "jest": "29.7.0",
    "prettier": "3.5.3",
    "prettier-eslint": "16.3.0",
    "prisma": "6.5.0",
    "ts-jest": "29.3.0",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.28.0"
  },
  "overrides": {
    "minimatch": "9.0.9",
    "qs": "6.15.3",
    "@babel/core": "7.29.7",
    "form-data": "4.0.6",
    "js-yaml": "4.2.0",
    "then-request": {
      "form-data": "2.5.6"
    },
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "3.15.0"
    }
  },
  "dependencies": {
    "@dinero.js/calculator-bigint": "2.0.0-alpha.14",

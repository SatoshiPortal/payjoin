{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "ES2022",
    "noImplicitAny": false,
    "moduleResolution": "node",
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "paths": {
      "payjoin": ["./node_modules/payjoin/dist/nodejs/index"]
    },
    "sourceMap": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "outDir": "./build",
    "sourceRoot": "./src",
    "types": [
      "jest",
      "node"
    ]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules"
  ]
}
